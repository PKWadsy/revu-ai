{
  "name": "revu-ai",
  "version": "0.2.0",
  "description": "Parallel AI code review — pluggable agent harnesses (Claude Code, opencode); pick any provider/model",
  "type": "module",
  "bin": {
    "revu-ai": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "code-review",
    "ai",
    "claude",
    "anthropic",
    "cli",
    "git",
    "diff",
    "review",
    "static-analysis",
    "mcp",
    "agent"
  ],
  "author": "PKWadsworth",
  "license": "MIT",
  "homepage": "https://github.com/PKWadsy/revu-ai#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PKWadsy/revu-ai.git"
  },
  "bugs": {
    "url": "https://github.com/PKWadsy/revu-ai/issues"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opencode-ai/sdk": "^1.14.41",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.2",
    "undici": "^7.25.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
